# Minimal required setup
KNOWLEDGE_BASE_DIR=examples/minimal-kb

# LLM
LLM_BASE_URL=http://127.0.0.1:8000/v1/
MODEL_NAME=Qwen/Qwen3-14B-AWQ
LLM_API_KEY=empty

# Common toggles
CLEAN_SKIP_EXISTING=true
RAW_DESENSITIZE=false
LOG_LEVEL=INFO

# Optional root overrides
# RAW_DIR=_raw
# CONTENT_DIR=content
# WIKI_DIR=wiki
# DATA_DIR=data

# Optional runtime overrides
# TEMPERATURE=0.0
# LLM_TIMEOUT_SECONDS=180
# LLM_MAX_RETRIES=2
# COMPILER_WORKERS=4
# RESEARCH_DRAFT_MAX_NOTES=8
# RESEARCH_DRAFT_OVERWRITE_EXISTING=false
# PROMPT_TEMPLATES=prompts
